<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TopBar -->
    <include
        android:id="@+id/topBar"
        layout="@layout/view_top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Champ de recherche -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearchLibrary"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:hint="Rechercher une espèce…"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearchLibrary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:singleLine="true"
            android:textSize="15sp"
            android:fontFamily="@font/gentium_plus_regular" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Chips campus + reset -->
    <HorizontalScrollView
        android:id="@+id/chipScrollLib"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tilSearchLibrary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterCampusLib"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campus"
                android:fontFamily="@font/gentium_plus_regular" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipResetLib"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Réinitialiser"
                android:fontFamily="@font/gentium_plus_regular" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Compteur de résultats -->
    <TextView
        android:id="@+id/tvLibraryCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="@color/grey"
        android:fontFamily="@font/gentium_plus_italic"
        app:layout_constraintTop_toBottomOf="@id/chipScrollLib"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Grille des espèces
         paddingBottom="80dp" : 56dp (nav bar) + 24dp de marge de confort
         clipToPadding="false" : le dernier item peut scroller au-dessus de la nav bar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewLibrary"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvLibraryCount"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Chargement -->
    <ProgressBar
        android:id="@+id/progressBarLibrary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvLibraryCount"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Liste vide -->
    <TextView
        android:id="@+id/tvLibraryEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aucune espèce ne correspond à votre recherche."
        android:textSize="14sp"
        android:textColor="@color/grey"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        android:fontFamily="@font/gentium_plus_italic"
        app:layout_constraintTop_toBottomOf="@id/tvLibraryCount"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>