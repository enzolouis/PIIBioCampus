<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="@drawable/item_user_border">

    <!-- user picture -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/userAvatar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/bzz"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CircleImage"
        android:contentDescription="Temp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/circle_background2"/>

    <!-- username -->
    <TextView
        android:id="@+id/userPseudo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ember"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/gentium_plus_bold"
        android:textColor="@color/black"
        android:ellipsize="end"
        android:singleLine="true"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/userAvatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/userAvatar"
        app:layout_constraintBottom_toTopOf="@id/userDesc"/>

    <!-- description -->
    <TextView
        android:id="@+id/userDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Description de l'utilisateur"
        android:textSize="13sp"
        android:textColor="@color/grey"
        android:ellipsize="end"
        android:maxLines="2"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toEndOf="@id/userAvatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/userPseudo"
        app:layout_constraintBottom_toBottomOf="@id/userAvatar"/>

</androidx.constraintlayout.widget.ConstraintLayout>