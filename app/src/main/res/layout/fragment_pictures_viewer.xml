<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_rounded_white"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/ivAuthorProfile"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/user_circle"
                android:scaleType="centerCrop"
                android:layout_marginEnd="10dp"
                android:visibility="gone"
                android:contentDescription="Photo de profil de l'auteur" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Non identifié"
                android:fontFamily="@font/kg_blank_space_solid"
                />

            <!-- Statut validation/recensement : remplace l'ancien badge check -->
            <TextView
                android:id="@+id/tvValidationStatus"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="3"
                android:lineSpacingExtra="1dp"
                android:gravity="end"
                android:fontFamily="@font/gentium_plus_regular"
                android:visibility="gone" />

        </LinearLayout>



        <!-- Ligne 2 : image zoomable -->
        <com.github.chrisbanes.photoview.PhotoView
            android:id="@+id/photoView"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:scaleType="fitCenter"
            android:layout_marginBottom="6dp" />

        <!-- Ligne 3 : date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/grey"
            android:layout_marginBottom="10dp"
            android:text="Date inconnue"
            android:fontFamily="@font/gentium_plus_italic"
            />

        <!-- Ligne 4 : description taxonomique -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="14dp"
            android:text="@string/famille_genre_espece"
            android:fontFamily="@font/gentium_plus_bold"
            />

        <!-- Ligne 5 : reprendre recensement -->
        <Button
            android:id="@+id/btnResumeCensus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reprendre_le_recensement"
            style="@style/ButtonPrimaryOutlined"
            android:textAllCaps="false"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Ligne 6 : Valider | Retour | Supprimer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3">

            <Button
                android:id="@+id/btnValidate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/valider"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:layout_marginEnd="4dp"
                android:fontFamily="@font/kg_blank_space_solid"
                android:visibility="gone"
                style="@style/ButtonSuccess" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/retour"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:fontFamily="@font/kg_blank_space_solid"
                android:layout_marginHorizontal="4dp"
                style="@style/ButtonPrimary" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/supprimer"
                android:textAllCaps="false"
                android:layout_marginStart="4dp"
                android:visibility="gone"
                style="@style/ButtonDanger"
                android:maxLines="1"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="8sp"
                app:autoSizeMaxTextSize="13sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>