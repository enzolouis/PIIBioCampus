<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/topBar"
            layout="@layout/view_top_bar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineHalf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.55" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/listContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="12dp"
            android:background="@drawable/bg_section"
            android:elevation="4dp"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toTopOf="@id/guidelineHalf"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/titleList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/actualites_title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/gentium_plus_bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                app:layout_constraintTop_toBottomOf="@id/titleList"
                app:layout_constraintBottom_toTopOf="@id/btnAddNews"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <Button
                android:id="@+id/btnAddNews"
                style="@style/ButtonPrimary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="@string/ajouter_une_actualite"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/featuredContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="0dp"
            android:background="@drawable/bg_section"
            android:elevation="4dp"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/guidelineHalf"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/titleFeatured"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/la_fneb_et_ses_projets"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/gentium_plus_bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/featuredMain"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder_image"
                app:shapeAppearanceOverlay="@style/roundedImageView"
                app:layout_constraintTop_toBottomOf="@id/titleFeatured"
                app:layout_constraintBottom_toTopOf="@id/featuredLeft"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_weight="1"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/featuredLeft"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="4dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder_image"
                app:shapeAppearanceOverlay="@style/roundedImageView"
                app:layout_constraintTop_toBottomOf="@id/featuredMain"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/featuredRight"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintVertical_weight="1"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/featuredRight"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="4dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder_image"
                app:shapeAppearanceOverlay="@style/roundedImageView"
                app:layout_constraintTop_toBottomOf="@id/featuredMain"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/featuredLeft"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_weight="1"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>