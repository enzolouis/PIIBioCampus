<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F4">

    <!-- Top Bar -->
    <include
        android:id="@+id/topBar"
        layout="@layout/view_top_bar" />

    <!-- Filtres scrollables horizontalement -->
    <HorizontalScrollView
        android:id="@+id/filtersScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:background="@android:color/white"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Utilisateur"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:checkable="false"
                android:fontFamily="@font/gentium_plus_bold"
                />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterCampus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campus"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:checkable="false"
                android:fontFamily="@font/gentium_plus_bold"
                />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterValidated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Validé"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:checkable="true"
                android:fontFamily="@font/gentium_plus_bold"
                />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterNotValidated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Non validé"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:checkable="true"
                android:fontFamily="@font/gentium_plus_bold"
                />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:checkable="false"
                android:fontFamily="@font/gentium_plus_bold"
                />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Réinitialiser"
                style="@style/Widget.MaterialComponents.Chip.Action"
                app:chipBackgroundColor="@color/red"
                android:textColor="@color/white" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Résumé filtres actifs + compteur -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvActiveFilters"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="@color/grey"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvResultCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:text="0 photo(s)" />

    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC" />

    <!-- Grille de photos (même RecyclerView que MyProfile) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/photosRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />

    <!-- Indicateur de chargement -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Message vide -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aucune photo trouvée"
        android:gravity="center"
        android:padding="32dp"
        android:textSize="15sp"
        android:textColor="@color/grey"
        android:visibility="gone" />

</LinearLayout>
