<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_white"
    android:padding="8dp"
    android:elevation="4dp">

    <!-- Miniature cliquable -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="120dp">

        <ImageView
            android:id="@+id/photo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/photo_placeholder" />

        <!-- Point rouge en haut à droite : recordingStatus == false -->
        <View
            android:id="@+id/ivRecordingDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="top|end"
            android:layout_margin="5dp"
            android:background="@drawable/bg_dot_red"
            android:visibility="gone" />

        <!-- Point vert en haut à droite : adminValidated == true -->
        <View
            android:id="@+id/ivValidatedBadge"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="top|end"
            android:layout_margin="5dp"
            android:background="@drawable/bg_dot_green"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Titre (espèce / genre / famille) -->
    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="—" />

</LinearLayout>