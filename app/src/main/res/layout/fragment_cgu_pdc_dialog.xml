<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_rounded_white"
    android:padding="16dp">

    <!-- Titre -->
    <TextView
        android:id="@+id/tvPoCTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_cgu_pcd"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:paddingBottom="12dp"
        android:fontFamily="@font/kg_blank_space_solid"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Séparateur -->
    <View
        android:id="@+id/dividerPoC"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/grey"
        app:layout_constraintTop_toBottomOf="@id/tvPoCTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Indication de scroll -->
    <TextView
        android:id="@+id/tvScrollHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/sub_title_cgu_pcd"
        android:textSize="12sp"
        android:textColor="?attr/colorPrimary"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:fontFamily="@font/gentium_plus_italic"
        app:layout_constraintTop_toBottomOf="@id/dividerPoC"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contenu scrollable -->
    <ScrollView
        android:id="@+id/scrollViewPoC"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbarStyle="insideOverlay"
        app:layout_constraintTop_toBottomOf="@id/tvScrollHint"
        app:layout_constraintBottom_toTopOf="@id/dividerBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvPoCContentCGU"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/black"
                android:lineSpacingExtra="3dp"
                android:fontFamily="@font/gentium_plus_regular"
                android:text="@string/cgu_full_text" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@color/black"
                android:alpha="0.12" />

            <TextView
                android:id="@+id/tvPoCContentPDC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/black"
                android:lineSpacingExtra="3dp"
                android:fontFamily="@font/gentium_plus_regular"
                android:text="@string/Politique_de_confidentitalite" />

        </LinearLayout>
    </ScrollView>

    <!-- Séparateur bas -->
    <View
        android:id="@+id/dividerBottom"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/grey"
        app:layout_constraintBottom_toTopOf="@id/btnRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Boutons -->
    <LinearLayout
        android:id="@+id/btnRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnDeclinePoC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Je refuse"
            android:textAllCaps="false"
            style="@style/ButtonDanger" />

        <Button
            android:id="@+id/btnAcceptPoC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="J'accepte"
            android:textAllCaps="false"
            android:enabled="false"
            style="@style/ButtonSuccess" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
