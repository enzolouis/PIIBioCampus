<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_rounded_white"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image de l'espèce -->
        <ImageView
            android:id="@+id/ivSpeciesImage"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder_image"
            android:layout_marginBottom="12dp" />

        <!-- Nom de l'espèce -->
        <TextView
            android:id="@+id/tvSpeciesName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/kg_blank_space_solid" />

        <!-- Statut de recensement utilisateur·ice -->
        <TextView
            android:id="@+id/tvRecordStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/gentium_plus_bold" />

        <!-- Compteur global de recensements -->
        <TextView
            android:id="@+id/tvRecordCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/grey"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/gentium_plus_italic" />

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey"
            android:layout_marginBottom="12dp" />

        <!-- Hiérarchie taxonomique -->
        <TextView
            android:id="@+id/tvTaxonomyPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/gentium_plus_bold" />

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey"
            android:layout_marginBottom="12dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvSpeciesDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/gentium_plus_regular" />

        <!-- Bouton Fermer -->
        <Button
            android:id="@+id/btnCloseSpecies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fermer"
            android:textAllCaps="false"
            style="@style/ButtonPrimary" />

    </LinearLayout>
</ScrollView>
