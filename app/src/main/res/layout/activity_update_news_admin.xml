<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/topBar"
        layout="@layout/view_top_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/pictureNews"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:shapeAppearanceOverlay="@style/roundedImageView"
        android:src="@drawable/ic_launcher_foreground"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnChangeImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Changer l'image"
        android:layout_marginTop="12dp"

        app:layout_constraintTop_toBottomOf="@id/pictureNews"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/labelTitleNews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Titre"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnChangeImage"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"/>

    <EditText
        android:id="@+id/titleNews"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/fields_round_border"
        android:paddingStart="10dp"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/labelTitleNews"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="24dp"/>

    <TextView
        android:id="@+id/labelSourceNews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Source"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/titleNews"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"/>

    <EditText
        android:id="@+id/sourceNews"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/fields_round_border"
        android:paddingStart="10dp"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/labelSourceNews"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="24dp"/>

    <Button
        android:id="@+id/btnSuppr"
        style="@style/ButtonDanger"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Supprimer"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/sourceNews"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnValideUpdate"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="8dp"/>

    <Button
        android:id="@+id/btnValideUpdate"
        style="@style/ButtonSuccess"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Appliquer"
        android:enabled="true"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/sourceNews"
        app:layout_constraintStart_toEndOf="@id/btnSuppr"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>