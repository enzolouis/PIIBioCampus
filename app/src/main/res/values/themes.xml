<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PIIBioCampus" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Bouton" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:shape">rectangle</item>
        <item name="android:height">70dp</item>
        <item name="android:width">150dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">20sp</item>
        <!--        <item name="android:layout_alignParentBottom">false</item>-->
        <!--        <item name="android:layout_centerInParent">true</item>-->
        <!--        <item name="android:layout_marginBottom">30dp</item>-->
    </style>

    <style name="Theme.PIIBioCampus" parent="Base.Theme.PIIBioCampus" />

    <!-- Pop-up standard (MAP et MY_PROFILE) : fond semi-transparent, coins arrondis -->
    <style name="DialogPopup" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowElevation">8dp</item>
        <item name="colorSurface">@android:color/white</item>
    </style>

    <!-- Plein écran (ADMIN et CENSUS_TREE) -->
    <style name="DialogFullscreen" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="ButtonPrimary" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/kg_blank_space_solid</item>
        <item name="android:textColor">@color/white</item>
        <!-- radius inutile ici : à contrôler dans drawable/fade_buttonprimary -->
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:minHeight">56dp</item>

        <!-- no outlined config -->
        <item name="elevation">10dp</item>
        <item name="android:translationZ">10dp</item>
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:background">@drawable/fade_buttonprimary</item>
    </style>

    <style name="ButtonPrimaryOutlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/kg_blank_space_solid</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:minHeight">56dp</item>

        <!-- outlined config -->
        <item name="strokeColor">@color/light_border2</item>
        <item name="strokeWidth">1dp</item>
    </style>

</resources>