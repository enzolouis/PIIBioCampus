<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Button (plein) -->
    <style name="ButtonBase" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/kg_blank_space_solid</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:elevation">10dp</item>
        <item name="android:translationZ">10dp</item>
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>
    </style>

    <!-- Large Button (padding / taille / minHeight) -->
    <style name="ButtonLarge" parent="ButtonBase">
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Small Button -->
    <style name="ButtonSmall" parent="ButtonBase">
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:minHeight">35dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Base Outlined Button -->
    <style name="ButtonOutlinedBase" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/kg_blank_space_solid</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/light_border2</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Large Outlined Button -->
    <style name="ButtonOutlinedLarge" parent="ButtonOutlinedBase">
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Small Outlined Button -->
    <style name="ButtonOutlinedSmall" parent="ButtonOutlinedBase">
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:minHeight">35dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Types de boutons pleins -->

    <!-- Primary -->
    <style name="ButtonPrimary" parent="ButtonLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/fade_buttonprimary</item>
    </style>

    <!-- Secondary -->
    <style name="ButtonSecondary" parent="ButtonLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/fade_buttonsecondary</item>
    </style>

    <!-- Success -->
    <style name="ButtonSuccess" parent="ButtonLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/fade_buttonsuccess</item>
    </style>

    <!-- Danger -->
    <style name="ButtonDanger" parent="ButtonLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/fade_buttondanger</item>
    </style>

    <!-- Small Danger -->
    <style name="ButtonSmallDanger" parent="ButtonSmall">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/fade_buttondanger</item>
    </style>

    <!-- Types de boutons outlined -->

    <!-- Primary Outlined -->
    <style name="ButtonPrimaryOutlined" parent="ButtonOutlinedLarge">
        <item name="android:textColor">@color/primary</item>
    </style>

    <!-- Secondary Outlined -->
    <style name="ButtonSecondaryOutlined" parent="ButtonOutlinedLarge">
        <item name="android:textColor">@color/secondary</item>
    </style>

    <!-- Success Outlined -->
    <style name="ButtonSuccessOutlined" parent="ButtonOutlinedLarge">
        <item name="android:textColor">@color/green</item>
    </style>

    <!-- Danger Outlined -->
    <style name="ButtonDangerOutlined" parent="ButtonOutlinedLarge">
        <item name="android:textColor">@color/danger</item>
    </style>

    <!-- Small Danger Outlined -->
    <style name="ButtonSmallDangerOutlined" parent="ButtonOutlinedSmall">
        <item name="android:textColor">@color/danger</item>
    </style>
</resources>